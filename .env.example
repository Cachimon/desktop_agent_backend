# ==================== Database ====================
# Driver: mysql+aiomysql (async runtime) + mysql+pymysql (sync/Alembic)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_DATABASE=ai_assistant
DB_POOL_SIZE=20
DB_POOL_TIMEOUT=30

# ==================== Auth (JWT) ====================
AUTH_JWT_PRIVATE_KEY_PATH=./keys/private.pem
AUTH_JWT_PUBLIC_KEY_PATH=./keys/public.pem
AUTH_JWT_ALGORITHM=RS256
AUTH_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
AUTH_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== Auth (SMTP) ====================
AUTH_SMTP_HOST=smtp.example.com
AUTH_SMTP_PORT=587
AUTH_SMTP_USER=your_email@example.com
AUTH_SMTP_PASSWORD=your_smtp_password
AUTH_SMTP_USE_TLS=true

# ==================== Auth (Verification Code) ====================
AUTH_VERIFICATION_CODE_LENGTH=6
AUTH_VERIFICATION_CODE_EXPIRE_MINUTES=5
AUTH_VERIFICATION_CODE_MAX_ATTEMPTS=3

# ==================== Auth (Rate Limiting) ====================
AUTH_SEND_CODE_COOLDOWN_SECONDS=60
AUTH_SEND_CODE_DAILY_LIMIT=5
AUTH_LOGIN_FAILURE_LOCKOUT_THRESHOLD=5
AUTH_LOGIN_FAILURE_LOCKOUT_WINDOW_MINUTES=15
AUTH_LOGIN_FAILURE_LOCKOUT_DURATION_MINUTES=30
AUTH_IP_RATE_LIMIT_PER_MINUTE=100
AUTH_IP_ANOMALY_EMAIL_THRESHOLD=10
AUTH_IP_ANOMALY_WINDOW_HOURS=1

# ==================== LLM ====================
LLM_MODEL_NAME=gpt-4o-mini
LLM_API_KEY=your_llm_api_key
LLM_API_BASE=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ==================== Agent ====================
AGENT_SKILLS_DIR=.agents/skills
AGENT_SANDBOX_TIMEOUT_SECONDS=30
AGENT_SANDBOX_CPU_LIMIT_PERCENT=50
AGENT_SANDBOX_MEMORY_LIMIT_MB=512
AGENT_SSE_HEARTBEAT_SECONDS=30
AGENT_SSE_MAX_CONNECTIONS_PER_CLIENT=5
AGENT_SSE_MAX_MESSAGE_SIZE_MB=10

# ==================== App ====================
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=false
APP_CORS_ORIGINS=["http://localhost:*","electron://*"]
APP_LOG_LEVEL=INFO
APP_API_V1_PREFIX=/api/v1
